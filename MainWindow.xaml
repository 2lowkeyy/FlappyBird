<Window x:Class="FlappyBird.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flappy Bird" Height="600" Width="400"
        Background="SkyBlue" KeyDown="Window_KeyDown">
    <Canvas x:Name="Canvas">

        <Image x:Name="BirdImg" Width="40" Height="30"
               Source="Assets/bird.png"
               Canvas.Left="100" Canvas.Top="270"/>

        <Rectangle Width="400" Height="60" Fill="#8B4513" Canvas.Bottom="0"/>

        <TextBlock x:Name="TxtPuntos" Text="0"
                   FontSize="36" FontWeight="Bold" Foreground="White"
                   Canvas.Top="20" Canvas.Left="180"/>

        <StackPanel x:Name="PanelInicio"
                    Canvas.Top="150" Canvas.Left="75" Width="250" Visibility="Visible">
            <TextBlock Text="FLAPPY BIRD" FontSize="30" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Text="Pon tu nombre" FontSize="18" Foreground="White" FontWeight="Bold"
                       Margin="0,16,0,4"/>
            <TextBox x:Name="TxtNombre" Text=" " FontSize="16" Margin="0,0,0,8"/>
            <Button Content="Jugar"       Click="Jugar_Click"
                    Background="Green"   Foreground="White" FontSize="18" Margin="0,8,0,8"/>
            <Button Content="Records"     Click="VerRecordsInicio_Click"
                    Background="DarkBlue" Foreground="White" FontSize="18" Margin="0,0,0,8"/>
            <Button Content="Salir"       Click="Salir_Click"
                    Background="DarkRed" Foreground="White" FontSize="18"/>
        </StackPanel>

        <StackPanel x:Name="PanelGameOver"
                    Canvas.Top="160" Canvas.Left="75" Width="250" Visibility="Collapsed">
            <TextBlock Text="Perdiste Bajo a Jobo" FontSize="24" FontWeight="Bold"
                       Foreground="Red" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtPuntajeFinal" FontSize="18" Foreground="White"
                       HorizontalAlignment="Center" Margin="0,8,0,8"/>
            <Button Content="Guardar"     Click="Guardar_Click"
                    Background="Green"   Foreground="White" FontSize="16" Margin="0,0,0,4"/>
            <Button Content="Ver Records" Click="VerRecords_Click"
                    Background="DarkBlue" Foreground="White" FontSize="16" Margin="0,0,0,4"/>
            <Button Content="Salir"       Click="Salir_Click"
                    Background="DarkRed" Foreground="White" FontSize="16"/>
        </StackPanel>

        <StackPanel x:Name="PanelRecords"
                    Canvas.Top="100" Canvas.Left="75" Width="250" Visibility="Collapsed">
            <TextBlock Text="TOP 10" FontSize="30" FontWeight="Bold"
                       Foreground="Gold" HorizontalAlignment="Center"/>
            <ListBox x:Name="ListaRecords" Height="320" FontSize="14"
                     Background="#BB000000" Foreground="White"/>
            <Button Content="Jugar de nuevo" Click="JugarDeNuevo_Click"
                    Background="Green" Foreground="White" FontSize="16" Margin="0,6,0,0"/>
        </StackPanel>

    </Canvas>
</Window>
